index 3c16a84..a503fd6 100644
--- a/cl_dll/input.cpp
+++ b/cl_dll/input.cpp
@@ -21,6 +21,8 @@
 #include "vgui_TeamFortressViewport.h"
 #include "filesystem_utils.h"
 
+#include "toshl_hooks.h" // TempleOS-HL1
+
 
 extern bool g_iAlive;
 
@@ -754,6 +756,16 @@ void DLLEXPORT CL_CreateMove(float frametime, struct usercmd_s* cmd, int active)
 	{
 		VectorCopy(oldangles, cmd->viewangles);
 	}
+
+	// TempleOS-HL1: detect the +use rising edge (enters terminal mode when
+	// looking at a monitor), and freeze the player while driving a terminal.
+	TOSHL_OnUseState((in_use.state & 1) != 0);
+	if (0 != TOSHL_WantsMovementLock())
+	{
+		cmd->forwardmove = cmd->sidemove = cmd->upmove = 0;
+		cmd->buttons &= ~(IN_ATTACK | IN_ATTACK2 | IN_JUMP | IN_DUCK |
+						  IN_FORWARD | IN_BACK | IN_MOVELEFT | IN_MOVERIGHT | IN_USE);
+	}
 }
 
